# API base URL for the iqama-engine backend.
# When set, the app skips the manual URL setup screen on first load.
# The user can still override this value from within the app.
# NOTE: Do NOT include /api suffix - the service files already include /api/v1/ in their paths
# Example for production: https://iqama.theisbc.ca
VITE_API_BASE_URL=http://localhost:3000

# Base path for the application (used for routing and assets)
# Use "/" for root deployment or "/ui/" for subdirectory deployment
VITE_BASE_PATH=/
