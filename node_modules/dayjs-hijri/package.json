{
  "name": "dayjs-hijri",
  "version": "1.0.1",
  "description": "A Hijri calendar (Based on Umm al-Qura calculations) plugin for day.js.",
  "main": "dist/hijri-day.cjs.min.js",
  "web": "dist/hijri-day.umd.min.js",
  "module": "dist/hijri-day.esm.js",
  "jsnext:main": "dist/hijri-day.esm.js",
  "scripts": {
    "test": "jest",
    "release": "standard-version",
    "build": "rollup -c",
    "check-size": "bundlesize",
    "size": "size-limit"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "test"
    ],
    "testRegex": "test/(.*?/)?.*test.js$",
    "coverageDirectory": "./coverage/",
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*"
    ],
    "transform": {
      "^.+\\.js$": "<rootDir>/jest.transform.js"
    }
  },
  "size-limit": [
    {
      "limit": "2.99 KB",
      "path": "dist/hijri-day.umd.min.js",
      "ignore": [
        "dayjs"
      ]
    },
    {
      "limit": "2.99 KB",
      "path": "dist/hijri-day.cjs.min.js",
      "ignore": [
        "dayjs"
      ]
    }
  ],
  "bundlesize": [
    {
      "path": "dist/hijri-day.cjs.js",
      "maxSize": "5 kB"
    },
    {
      "path": "dist/hijri-day.esm.js",
      "maxSize": "5 kB"
    },
    {
      "path": "dist/hijri-day.umd.js",
      "maxSize": "5 kB"
    }
  ],
  "keywords": [
    "hijri",
    "hijriah",
    "arabic",
    "lunar",
    "Umm al-Qura",
    "date",
    "calendar",
    "conversion",
    "convert",
    "day.js",
    "dayjs",
    "plugin",
    "moment",
    "dayjs-hijri",
    "plugin",
    "gregorian"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mashhadiebad/dayjs-hijri"
  },
  "author": "MohammadHossein MashhadiEbad",
  "license": "MIT",
  "devDependencies": {
    "@babel/preset-env": "^7.26.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@size-limit/preset-small-lib": "^11.1.6",
    "babel-jest": "^29.7.0",
    "dayjs": "^1.11.13",
    "jest": "^29.7.0",
    "mockdate": "^3.0.5",
    "prettier": "^3.4.2",
    "rollup": "^4.30.1",
    "rollup-plugin-gzip": "^4.0.1",
    "size-limit": "^11.1.6",
    "standard-version": "^9.5.0"
  }
}
